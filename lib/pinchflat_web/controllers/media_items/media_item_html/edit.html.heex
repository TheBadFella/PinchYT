<div class="mb-6 flex gap-3 flex-row items-center">
  <h2 class="ml-4 truncate text-title-md2 font-bold text-theme-on-surface">Editing "{@media_item.title}"</h2>
</div>

<div class="theme-surface-raised px-5 pb-2.5 pt-6 sm:px-7.5 xl:pb-1">
  <div class="max-w-full">
    <div class="flex flex-col gap-10">
      <.media_item_form changeset={@changeset} action={~p"/sources/#{@media_item.source_id}/media/#{@media_item}"} />
    </div>
  </div>
</div>
